# ── Laravel API ────────────────────────────────────────────────
LARAVEL_API_URL=http://host.docker.internal:8000/api
# REQUERIDO — sin token el push de señales se omite (solo deja warning en logs).
LARAVEL_ADMIN_TOKEN=                # Bearer token de admin (obtener con POST /api/auth/login)

# Slugs de tenants que reciben las señales, separados por coma (vacío = single-tenant).
# ⚠ Cada señal aceptada se replica a TODOS los slugs listados: si los tenants
#   monitorean candidatos distintos, corre una instancia de ingest por candidato.
TENANT_SLUGS=

# ── Candidatos a monitorear ────────────────────────────────────
# REQUERIDO — sin valor el scraper descarta todos los artículos.
# Nombres/alias del candidato que el clasificador buscará en los textos.
# Ejemplo: TARGET_CANDIDATES=maria torres,torres,lima norte
TARGET_CANDIDATES=

# ── Twitter API v2 (opcional — plan Basic $200/mes) ────────────
TWITTER_BEARER_TOKEN=
# Ejemplo: TWITTER_KEYWORDS=maria torres alcaldesa,elecciones lima 2026
TWITTER_KEYWORDS=

# ── YouTube Data API v3 (gratis — 10 000 unidades/día) ─────────
YOUTUBE_API_KEY=
YOUTUBE_CHANNELS=                   # IDs de canales a monitorear, separados por coma

# ── RSS Feeds de medios peruanos (gratis) ──────────────────────
RSS_FEEDS=https://rpp.pe/rss/peru.xml,https://elcomercio.pe/feed/politica,https://larepublica.pe/rss,https://gestion.pe/feed/

# ── Groq (clasificación rápida — modelo gratuito disponible) ───
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── OpenAI (para embeddings en Qdrant) ────────────────────────
OPENAI_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small

# ── Qdrant (vector store para RAG) ────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ── Redis (broker de Celery) ───────────────────────────────────
REDIS_URL=redis://redis:6379
