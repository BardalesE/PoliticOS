# ══════════════════════════════════════════════════════════════════
# PoliticOS Ingest — plantilla de configuración
#
# PRODUCCIÓN (una instancia por candidato): NO edites este archivo.
# La config de cada instancia se genera desde Laravel con
#   php artisan tenant:ingest-config <slug>
# y queda en instances/<slug>.env (gitignored). Se levanta con:
#   docker compose -f docker-compose.instance.yml -p ingest-<slug> \
#     --env-file instances/<slug>.env up -d
#
# DESARROLLO (stack single-tenant de docker-compose.yml): copia este
# archivo a .env y rellena.
# ══════════════════════════════════════════════════════════════════

# ── Tenant de esta instancia ───────────────────────────────────
# Slug del tenant al que se postean las señales (header X-Tenant).
# Vacío = single-tenant (BD por defecto). Legado: TENANT_SLUGS (lista)
# aún se acepta tomando el primer slug.
TENANT_SLUG=

# ── Laravel API ────────────────────────────────────────────────
LARAVEL_API_URL=http://host.docker.internal:8000/api
# REQUERIDO — sin key el push de señales se omite (solo deja warning en logs).
# Secreto compartido con Laravel (header X-Ingest-Key); debe coincidir con
# INGEST_KEY del .env de Laravel. Generar: openssl rand -hex 32
INGEST_KEY=

# ── Candidato a monitorear ─────────────────────────────────────
# REQUERIDO — sin valor el scraper descarta todos los artículos.
# Aliases del candidato de ESTA instancia, separados por coma.
# Legado: TARGET_CANDIDATES aún se acepta como fallback.
# Ejemplo: TARGET_ALIASES=maria torres,torres
TARGET_ALIASES=
# Keywords de búsqueda (Twitter / YouTube), separados por coma.
# Legado: TWITTER_KEYWORDS aún se acepta como fallback.
# Ejemplo: TARGET_KEYWORDS=maria torres alcaldesa,elecciones lima 2026
TARGET_KEYWORDS=

# ── Twitter API v2 (opcional — plan Basic $200/mes) ────────────
TWITTER_BEARER_TOKEN=

# ── YouTube Data API v3 (gratis — 10 000 unidades/día) ─────────
YOUTUBE_API_KEY=
YOUTUBE_CHANNELS=                   # IDs de canales a monitorear, separados por coma

# ── RSS Feeds de medios peruanos (gratis) ──────────────────────
RSS_FEEDS=https://rpp.pe/rss/peru.xml,https://elcomercio.pe/feed/politica,https://larepublica.pe/rss,https://gestion.pe/feed/

# ── Groq (clasificación rápida — modelo gratuito disponible) ───
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── OpenAI (para embeddings en Qdrant) ────────────────────────
OPENAI_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small

# ── Qdrant (vector store para RAG — compartido entre instancias) ─
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ── Redis (broker de Celery — propio de cada instancia) ────────
REDIS_URL=redis://redis:6379
