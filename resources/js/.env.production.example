# resources/js/.env.production.example
# Copia este archivo como .env.production en el servidor ANTES de `npm run build`.
# .env.production está en .gitignore — este ejemplo sí se commitea.

# ── API Laravel ──────────────────────────────────────────────────
# Sin dominio (IP directa VPS): NEXT_PUBLIC_API_URL=http://TU_IP/api
# Con dominio:                  NEXT_PUBLIC_API_URL=https://api.tudominio.pe/api
NEXT_PUBLIC_API_URL=http://TU_IP_O_DOMINIO/api

# ── Multi-tenancy ────────────────────────────────────────────────
# Sin dominio (IP directa): dejar vacío — usa ?tenant=slug en la URL.
# Con subdominio:           NEXT_PUBLIC_BASE_DOMAIN=tudominio.pe
NEXT_PUBLIC_BASE_DOMAIN=

# Un candidato fijo por servidor (opcional):
NEXT_PUBLIC_TENANT_SLUG=

NEXT_PUBLIC_USE_MOCK=false
