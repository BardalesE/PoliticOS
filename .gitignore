# ── Secrets — NUNCA commitear estos archivos ─────────────────────────────────
# Pre-commit hook instalado vía: git config core.hooksPath .githooks
# .githooks/ SÍ se commitea (contiene el scanner de secretos, no los secretos).
/.phpunit.cache
/node_modules
/public/build
/public/hot
/public/storage
/storage/*.key
/storage/pail
/vendor
.env
.env.backup
.env.production
.phpactor.json
.phpunit.result.cache
Homestead.json
Homestead.yaml
npm-debug.log
yarn-error.log
/auth.json
/.fleet
/.idea
/.nova
/.vscode
/.zed
# MCP config — contiene API keys de servidores MCP (TestSprite, etc.) en texto plano
/.mcp.json
# Artefactos generados por TestSprite MCP — tmp/config.json trae la API key de TestSprite
/testsprite_tests
/resources/js/testsprite_tests

# Next.js
/resources/js/node_modules
/resources/js/.next
/resources/js/.env
/resources/js/.env.local
/resources/js/.env.production
/resources/js/.env.development
/resources/js/.env.production.local
/resources/js/.env.development.local
/resources/js/.env.test.local
/resources/js/screenshots
/resources/js/test-results
/resources/js/tsconfig.tsbuildinfo
# Playwright QA — artefactos generados (la fuente de tests/ sí se versiona)
/resources/js/tests/reports
/resources/js/tests/screenshots
/resources/js/tests/test-artifacts

# Uploaded media / storage
/storage/app/public

# Large binaries and one-off files
*.pptx
/index.sql
/generate_pptx.py
/landing_bento_*.png
/politicos-v2-patch*/

# training-data/ SÍ se versiona (decisión 2026-06-12, ver
# docs/architecture/07-training-data-versioning.md). Contiene estrategia de
# campaña de clientes reales: si este repo se hace público, sacarla antes.

# Python — caches del pipeline de ingesta
__pycache__/
*.pyc
.pytest_cache/

# Redis dump (generado automáticamente por Redis)
dump.rdb

# Archivos de prueba locales
/resources/js/test-*.js
/resources/js/test-*.mjs
/landing-robertov2.html

# Logs de storage
/storage/logs/*.log
/storage/logs/bootstrap_debug.log
