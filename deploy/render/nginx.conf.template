# ─────────────────────────────────────────────────────────────────────────────
# PoliticOS — nginx para Render (contenedor único php-fpm + nginx)
# Plantilla: ${PORT} se sustituye en el arranque (entrypoint.sh via envsubst).
# Render inyecta PORT; el contenedor DEBE escuchar en ese puerto.
# ─────────────────────────────────────────────────────────────────────────────

server {
    listen ${PORT} default_server;
    listen [::]:${PORT} default_server;
    server_name _;

    root  /var/www/html/public;
    index index.php;

    # Uploads de media (fotos, PDFs del knowledge base)
    client_max_body_size 25m;

    # Render ya termina TLS; los headers de seguridad los pone la app
    # (App\Http\Middleware\SecurityHeaders), no duplicar aquí.

    # ── SSE — /api/chat/stream sin buffering ────────────────────────────────
    # Mismo criterio que deploy/nginx.conf (VPS): el chat streamea tokens.
    # La app además envía X-Accel-Buffering: no, que nginx respeta.
    location = /api/chat/stream {
        try_files $uri /index.php?$query_string;
    }

    # ── Archivos subidos (symlink public/storage → storage/app/public) ──────
    location /storage/ {
        expires 7d;
        add_header Cache-Control "public";
        try_files $uri =404;
    }

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_pass  127.0.0.1:9000;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        fastcgi_index index.php;

        # SSE / respuestas largas del LLM: sin buffering y timeout amplio
        fastcgi_buffering    off;
        fastcgi_read_timeout 300;
    }

    # Nunca servir dotfiles (.env, .git, etc.)
    location ~ /\.(?!well-known) {
        deny all;
    }
}
