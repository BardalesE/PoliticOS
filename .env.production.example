APP_NAME=PoliticOS
APP_ENV=production
APP_KEY=                          # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://api.politicos.pe

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ─── Database (main — tenant registry) ─────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bdpolitic
DB_USERNAME=politicos_user
DB_PASSWORD=your-strong-password

# ─── Session ────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.politicos.pe     # dot prefix = share across subdomains

# ─── Cache ──────────────────────────────────────────────────────────────────
CACHE_STORE=database

# ─── Queue ──────────────────────────────────────────────────────────────────
# Use database for basic setup; switch to redis for higher load
QUEUE_CONNECTION=database

# ─── Storage / S3 ───────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
MEDIA_DISK=s3                     # Switch from 'public' to 's3' here

AWS_ACCESS_KEY_ID=your-key-id
AWS_SECRET_ACCESS_KEY=your-secret
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=politicos-media
AWS_URL=                          # Optional CDN URL (CloudFront etc.)

# ─── Broadcast / Reverb ─────────────────────────────────────────────────────
BROADCAST_CONNECTION=log          # Upgrade to pusher/reverb for live features

# ─── Mail ───────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.postmarkapp.com
MAIL_PORT=587
MAIL_USERNAME=your-postmark-token
MAIL_PASSWORD=your-postmark-token
MAIL_FROM_ADDRESS=noreply@politicos.pe
MAIL_FROM_NAME="PoliticOS"

# ─── AI ─────────────────────────────────────────────────────────────────────
AI_PROVIDER=groq
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=sk-ant-...      # Fallback for Claude
CLAUDE_MODEL=claude-haiku-4-5-20251001
AI_MAX_TOKENS=600

# ─── Embeddings (RAG) ───────────────────────────────────────────────────────
AI_EMBEDDINGS_DRIVER=mysql_fulltext

# ─── Sanctum / CORS ─────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=.politicos.pe    # dot prefix = all subdomains
SESSION_DRIVER=cookie
SESSION_DOMAIN=.politicos.pe

FRONTEND_URL=https://politicos.pe
CORS_ALLOWED_PATTERN=https://([a-z0-9-]+\.)?politicos\.pe

# ─── SuperAdmin ─────────────────────────────────────────────────────────────
SUPER_ADMIN_KEY=change-this-before-launch

# ─── Next.js (set in resources/js/.env.production on the server) ─────────────
# NEXT_PUBLIC_API_URL=https://api.politicos.pe/api
# NEXT_PUBLIC_BASE_DOMAIN=politicos.pe  # enables subdomain-based tenant detection
# NEXT_PUBLIC_TENANT_SLUG=             # leave empty — subdomain detection handles it
# NEXT_PUBLIC_USE_MOCK=false
