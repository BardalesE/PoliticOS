APP_NAME=PoliticOS
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# PRODUCCIÓN: usar LOG_STACK=daily y LOG_LEVEL=warning
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug
LOG_DAYS=14

# ── Base de datos ─────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bdpolitic
DB_USERNAME=root
DB_PASSWORD=

# ── Sesiones / Cache ──────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_STORE=session
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=localhost
CACHE_STORE=redis

# ── Redis ─────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2

# ── CORS / Sanctum ────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
FRONTEND_URL=http://localhost:3000
# PRODUCCIÓN: CORS_ALLOWED_PATTERN=https://([a-z0-9-]+\.)?tudominio\.pe

# ── Multi-tenancy ─────────────────────────────────────────────────
# Slug del tenant activo en dev single-tenant (sin subdominios)
APP_TENANT_SLUG=james
# PRODUCCIÓN: APP_TENANT_SLUG= (vacío — se usan subdominios)

# Clave secreta para el panel super admin
# PRODUCCIÓN: generar con: openssl rand -hex 32
SUPER_ADMIN_KEY=change-this-secret-key-minimum-32-chars

# ── IA — el cerebro de James ──────────────────────────────────────
AI_PROVIDER=groq                  # groq | claude | openai
GROQ_API_KEY=                     # gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=                # sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=                   # sk-... (opcional)
OPENAI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=600

# ── Storage ───────────────────────────────────────────────────────
FILESYSTEM_DISK=local
# PRODUCCIÓN: MEDIA_DISK=s3 (o "public" si usas almacenamiento local)
MEDIA_DISK=public

# ── Queue / Mail ──────────────────────────────────────────────────
QUEUE_CONNECTION=redis
MAIL_MAILER=log
BROADCAST_CONNECTION=log
