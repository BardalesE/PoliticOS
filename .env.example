APP_NAME=PoliticOS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ── Base de datos ─────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bdpolitic
DB_USERNAME=root
DB_PASSWORD=

# ── Sesiones / Cache ──────────────────────────────────────────────
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost
CACHE_STORE=database

# ── CORS / Sanctum ────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# ── Multi-tenancy ─────────────────────────────────────────────────
# Slug del tenant activo en dev single-tenant (sin subdominios)
APP_TENANT_SLUG=james
# Clave secreta para el panel super admin
SUPER_ADMIN_KEY=change-this-secret-key

# ── IA — el cerebro de James ──────────────────────────────────────
AI_PROVIDER=groq                 # groq | claude | openai
GROQ_API_KEY=                    # gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=               # sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=                  # sk-... (opcional)
OPENAI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=600

# ── Queue / Mail (no requeridos en dev) ───────────────────────────
QUEUE_CONNECTION=database
MAIL_MAILER=log
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
